{
  "rewrites": [
    { "source": "/api/license-plate", "destination": "/api/license-plate" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/vehicle_db.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
